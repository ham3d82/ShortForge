# ─── Application ─────────────────────────────────────
APP_NAME=ShortForge
APP_VERSION=0.1.0
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret
ENVIRONMENT=development

# ─── Database (PostgreSQL) ──────────────────────────
DATABASE_URL=postgresql+asyncpg://shortforge:shortforge@localhost:5432/shortforge
DATABASE_SYNC_URL=postgresql://shortforge:shortforge@localhost:5432/shortforge

# ─── Redis (Celery Broker) ──────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Celery ─────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ─── Storage (S3 / MinIO) ──────────────────────────
STORAGE_BACKEND=s3
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
S3_BUCKET=shortforge-media
S3_ENDPOINT=http://localhost:9000
S3_USE_SSL=false

# ─── AI / LLM ───────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# ─── Text-to-Speech ─────────────────────────────────
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
AZURE_TTS_KEY=your-azure-key
AZURE_TTS_REGION=eastus

# ─── YouTube API ────────────────────────────────────
YOUTUBE_CLIENT_ID=your-google-client-id
YOUTUBE_CLIENT_SECRET=your-google-client-secret
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/auth/youtube/callback

# ─── Frontend ───────────────────────────────────────
FRONTEND_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8000/api

# ─── Media ──────────────────────────────────────────
MEDIA_OUTPUT_DIR=./backend/media/output
MEDIA_TEMP_DIR=./backend/media/temp
MAX_VIDEO_DURATION=60
DEFAULT_VIDEO_RESOLUTION=1080x1920
DEFAULT_FPS=30

# ─── Auth ───────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Sentry (Error Tracking) ────────────────────────
SENTRY_DSN=

# ─── Logging ────────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_FORMAT=json